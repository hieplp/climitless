{
  "name": "climitless",
  "version": "0.1.0",
  "description": "Schedule and auto-fire Claude sessions",
  "type": "module",
  "bin": {
    "climitless": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "daemon": "bun run src/daemon/index.ts",
    "test": "bun test",
    "format": "bunx prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "bunx prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "bunx tsc --noEmit && bunx eslint src tests",
    "lint:fix": "bunx eslint --fix src tests"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "pino": "^10.3.1",
    "smol-toml": "^1.6.0",
    "zod": "^4.3.6"
  }
}
